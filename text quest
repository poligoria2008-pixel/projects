import random
import sys

def safe_input(prompt=""):
    try:
        return input(prompt)
    except EOFError:
        # Если ввода нет — возвращаем пустую строку, чтобы программа не падала
        return ""

print('Участники команды Stray Kids ищут в заброшенном замке строчки от их ранее написанных песен и хотят выбраться, пока их не нашли злоумышленники.')
print('Играть нужно за участников команды Stray Kids. Они потеряли текст своей песни и не могут выбраться из замка. Противостоят им хейтеры, которые хотят уничтожить к-поп.')
print('У замка один этаж. Это прямоугольник 1 на 2, всего 2 комнаты. Из любой комнаты можно перейти в соседнюю.')

alive = True

while alive:
    print('Выберите действие, с которого хотите начать ход. Действия, которые могут выполнять участники Stray Kids: перемещение, атака, побег, поиск улик.')
    print('Выберите количество монстров в комнате, в которую вы отправитесь.')
    a = safe_input().strip().lower()
    if a == "":
        print('Нет ввода. Игра завершается.')
        break

    b_str = safe_input()
    if b_str == "":
        print('Нет ввода для количества монстров. Ставлю 0.')
        b = 0
    else:
        try:
            b = int(b_str)
            if b < 0:
                b = 0
        except ValueError:
            print('Некорректное число, ставлю 0 монстров.')
            b = 0

    if a == 'атака':
        if b != 0:
            print('Команда бьётся с монстрами!')

            hero_hp = random.randint(1, 16)
            hero_punch = random.randint(1, 16)
            monster_hp = random.randint(1, 16)
            monster_punch = random.randint(1, 16)

            while hero_hp > 0 and monster_hp > 0:
                monster_hp -= hero_punch
                if monster_hp <= 0:
                    monster_hp = 0
                    print('Герой наносит удар. Здоровье монстра: 0')
                    print('Монстр повержен!')
                else:
                    print('Герой наносит удар. Здоровье монстра:', monster_hp)
                    hero_hp -= monster_punch
                    if hero_hp < 0:
                        hero_hp = 0
                    print('Монстр наносит удар. Здоровье героя:', hero_hp)

            if hero_hp <= 0:
                alive = False
        else:
            print('Атаковать некого. Комната пуста.')

    elif a == 'перемещение' or a == 'поиск улик':
        if b != 0:
            print('В комнате монстры! Сначала нужно либо атаковать, либо попробовать сбежать.')
            a = 'побег'
        elif b == 0:
            if a == 'перемещение':
                print('Команда спокойно перемещается по комнате.')
            elif a == 'поиск улик':
                print('Команда обыскивает комнату и находит улику!')

    if a == 'побег' and b != 0:
        print('Выберите 1 или 2 комнату для побега.')
        room_str = safe_input()
        if room_str == "":
            print('Нет ввода номера комнаты. Попытка побега провалилась.')
            alive = False
            continue
        try:
            room = int(room_str)
        except ValueError:
            print('Неверный ввод. Попытка побега провалилась.')
            alive = False
            continue

        monster = random.random()
        if monster > 0.5:
            print('Монстр перехватил команду! Жизнь закончилась.')
            alive = False
        else:
            next_room = 2 if room == 1 else 1
            print(f'Побег удался! Команда переместилась в комнату номер {next_room}.')

    if a == 'поиск улик' and b != 0:
        print('Чтобы найти улику, нужно ввести пароль (в пароле 6 букв). У вас 3 попытки.')
        secret = 'смерть'
        attempts = 3
        found = False

        while attempts > 0 and not found:
            guess = safe_input(f'Попытка {4 - attempts}: введите пароль: ').strip().lower()
            if guess == "":
                print('Нет ввода пароля. Попытка считается проваленной.')
                attempts -= 1
                continue
            if guess == secret:
                print('Пароль подошёл! Команда нашла улику.')
                found = True
            else:
                attempts -= 1
                if attempts > 0:
                    print('Неверно. Попробуйте ещё раз.')
                else:
                    print('Все попытки исчерпаны. Улика не найдена.')

        if not found:
            alive = False

    if not alive:
        print()
        print('Игра окончена: команда не смогла выбраться.')
        break

    cont = safe_input('Хотите продолжить игру? (да/нет): ').strip().lower()
    if cont == "":
        print('Нет ввода ответа. Игра завершается.')
        break
    if cont not in ['да', 'д', 'yes', 'y']:
        print('Игра закончена.')
        break

